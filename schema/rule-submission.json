{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lumiosecurity/rules/schema/rule-submission.json",
  "title": "Virgil Rule Submission",
  "description": "Schema for community-contributed detection rules",
  "type": "object",
  "required": [
    "_meta",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": [
        "schemaVersion",
        "submittedAt",
        "confidence",
        "verticals",
        "ruleType"
      ],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "type": "string",
          "enum": [
            "1.0"
          ]
        },
        "submittedAt": {
          "type": "string",
          "format": "date-time"
        },
        "phishUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "campaignTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verticals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "financial",
              "crypto",
              "sso",
              "ecommerce",
              "general",
              "business",
              "cloud_storage",
              "entertainment",
              "gambling",
              "gaming",
              "government",
              "logistics",
              "messaging",
              "productivity",
              "social",
              "technology",
              "telecom"
            ]
          }
        },
        "ruleType": {
          "type": "string",
          "enum": [
            "domain",
            "source",
            "network",
            "combined"
          ]
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "iocs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domainRules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brandEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "vertical",
              "domains",
              "typos"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "vertical": {
                "type": "string",
                "enum": [
                  "financial",
                  "crypto",
                  "sso",
                  "ecommerce",
                  "general",
                  "business",
                  "cloud_storage",
                  "entertainment",
                  "gambling",
                  "gaming",
                  "government",
                  "logistics",
                  "messaging",
                  "productivity",
                  "social",
                  "technology",
                  "telecom"
                ]
              },
              "domains": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "typos": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "note": {
                "type": "string"
              },
              "created": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "updated": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "rev": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        },
        "signalFunctions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "description",
              "severity",
              "weight",
              "code"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^s-[a-z0-9-]+$"
              },
              "description": {
                "type": "string",
                "minLength": 5
              },
              "severity": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "weight": {
                "type": "number",
                "minimum": 0.05,
                "maximum": 0.5
              },
              "code": {
                "type": "string",
                "minLength": 10
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "sourcePatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "group",
          "description",
          "severity",
          "weight",
          "source"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "group": {
            "type": "string",
            "enum": [
              "cdnGating",
              "captchaGating",
              "phishkitSignatures",
              "botEvasion",
              "obfuscation",
              "credentialHarvesting",
              "socialEngineering",
              "brandImpersonation",
              "titleImpersonation",
              "typosquatPatterns",
              "urlHeuristics",
              "hostingPatterns",
              "suspiciousDomains"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 5
          },
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "weight": {
            "type": "number",
            "minimum": 0.05,
            "maximum": 0.5
          },
          "source": {
            "type": "string",
            "enum": [
              "html",
              "js",
              "both"
            ]
          },
          "note": {
            "type": "string"
          },
          "patternString": {
            "type": "string",
            "minLength": 3
          },
          "patternFlags": {
            "type": "string",
            "pattern": "^[gimsuy]*$"
          },
          "match": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "content": {
                  "type": "string",
                  "minLength": 1
                },
                "pattern": {
                  "type": "string",
                  "minLength": 1
                },
                "flags": {
                  "type": "string",
                  "pattern": "^[gimsuy]*$"
                },
                "fast_pattern": {
                  "type": "boolean"
                },
                "nocase": {
                  "type": "boolean"
                },
                "negated": {
                  "type": "boolean"
                },
                "depth": {
                  "type": "integer",
                  "minimum": 1
                },
                "within": {
                  "type": "integer",
                  "minimum": 1
                },
                "relative": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "condition": {
            "type": "string",
            "pattern": "^[\\d\\s&|!()]+$"
          },
          "created": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "updated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "rev": {
            "type": "integer",
            "minimum": 1
          }
        },
        "oneOf": [
          {
            "required": [
              "patternString"
            ]
          },
          {
            "required": [
              "match"
            ]
          }
        ]
      }
    },
    "ocrPatterns": {
      "type": "array",
      "description": "Patterns matched against OCR-extracted text from page screenshots. Used for image-heavy phishing pages where DOM text is sparse.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "severity",
          "weight",
          "match",
          "field"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "description": {
            "type": "string",
            "minLength": 5
          },
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "weight": {
            "type": "number",
            "minimum": 0.05,
            "maximum": 0.5
          },
          "match": {
            "type": "string",
            "enum": [
              "phrase",
              "brand_mismatch",
              "regex"
            ]
          },
          "field": {
            "type": "string",
            "enum": [
              "brandsMentioned",
              "credentialPhrases",
              "formLabels",
              "urgencyPhrases",
              "pageTitle",
              "externalLinks"
            ]
          },
          "phrases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "brands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "canonicalDomains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "patternString": {
            "type": "string"
          },
          "patternFlags": {
            "type": "string",
            "pattern": "^[gimsuy]*$"
          },
          "note": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "updated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "rev": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "networkPatterns": {
      "type": "array",
      "description": "Patterns matched against outbound HTTP request metadata (destination URLs, POST bodies, field names). Run in the content script exfiltration interceptor against live network requests.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "group",
          "description",
          "severity",
          "weight",
          "target",
          "patternString"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "group": {
            "type": "string",
            "enum": [
              "cdnGating",
              "captchaGating",
              "phishkitSignatures",
              "botEvasion",
              "obfuscation",
              "brandImpersonation",
              "credentialHarvesting",
              "socialEngineering",
              "titleImpersonation",
              "typosquatPatterns",
              "urlHeuristics",
              "hostingPatterns",
              "suspiciousDomains"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 5
          },
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "weight": {
            "type": "number",
            "minimum": 0.05,
            "maximum": 0.5
          },
          "target": {
            "type": "string",
            "enum": [
              "url",
              "body",
              "fieldNames",
              "any"
            ]
          },
          "transport": {
            "type": "string",
            "enum": [
              "any",
              "fetch",
              "xhr",
              "beacon",
              "websocket"
            ],
            "default": "any"
          },
          "patternString": {
            "type": "string",
            "minLength": 3
          },
          "patternFlags": {
            "type": "string",
            "pattern": "^[gimsuy]*$"
          },
          "note": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "updated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "rev": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "metaRules": {
      "type": "array",
      "description": "Cross-signal combination rules. Evaluated after all async signals merge. Can boost, replace, or downscore signal combinations.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "conditions",
          "action"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "conditions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "all": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/metaCondition"
                }
              },
              "any": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/metaCondition"
                }
              }
            }
          },
          "action": {
            "type": "object",
            "required": [
              "scope",
              "weight",
              "severity"
            ],
            "additionalProperties": false,
            "properties": {
              "scope": {
                "type": "string",
                "enum": [
                  "boost",
                  "replace",
                  "downscore"
                ]
              },
              "weight": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 0.6
              },
              "severity": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low",
                  "info"
                ]
              }
            }
          },
          "note": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "updated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "rev": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "$defs": {
    "numericOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lt": {
          "type": "number"
        },
        "lte": {
          "type": "number"
        },
        "gt": {
          "type": "number"
        },
        "gte": {
          "type": "number"
        },
        "eq": {
          "type": "number"
        },
        "neq": {
          "type": "number"
        }
      }
    },
    "metaCondition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal": {
          "type": "string"
        },
        "signal_group": {
          "type": "string",
          "enum": [
            "phishkitSignatures",
            "cdnGating",
            "captchaGating",
            "botEvasion",
            "obfuscation",
            "brandImpersonation",
            "credentialHarvesting",
            "socialEngineering",
            "titleImpersonation",
            "typosquatPatterns",
            "urlHeuristics",
            "hostingPatterns",
            "suspiciousDomains"
          ]
        },
        "signal_prefix": {
          "type": "string"
        },
        "where": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/numericOp"
          }
        },
        "has_form": {
          "type": "boolean"
        },
        "has_password_form": {
          "type": "boolean"
        },
        "has_credit_card_form": {
          "type": "boolean"
        },
        "has_external_form": {
          "type": "boolean"
        },
        "has_login_form": {
          "type": "boolean"
        },
        "has_visual_match": {
          "type": "boolean"
        },
        "visual_match_confidence": {
          "$ref": "#/$defs/numericOp"
        },
        "visual_match_brand": {
          "type": "string"
        },
        "has_dom_hash_match": {
          "type": "boolean"
        },
        "dom_hash_brand": {
          "type": "string"
        },
        "domain_age_hours": {
          "$ref": "#/$defs/numericOp"
        },
        "domain_age_days": {
          "$ref": "#/$defs/numericOp"
        },
        "heuristic_score": {
          "$ref": "#/$defs/numericOp"
        },
        "not": {
          "$ref": "#/$defs/metaCondition"
        }
      }
    }
  }
}
